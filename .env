# Log level (0 = none, 1 = info, 2 = verbose)
LOG_LEVEL=1

# Tileset optimization
TILESET_OPTIMIZATION=false
TILESET_OPTIMIZATION_QUALITY_MIN=0.9
TILESET_OPTIMIZATION_QUALITY_MAX=1.0

# Upload strategy: MAP_STORAGE (WorkAdventure map storage) or GH_PAGES
UPLOAD_MODE=MAP_STORAGE

# --- MAP_STORAGE upload settings ---
# For the local self-hosted workadv stack:
MAP_STORAGE_URL=http://map-storage.workadventure.localhost
UPLOAD_DIRECTORY=plex
# MAP_STORAGE_API_KEY goes in .env.secret (gitignored). For the local stack the
# map-storage also accepts basic auth john.doe / password.
